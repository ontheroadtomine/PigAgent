{
  "name": "nexa",
  "version": "1.0.0",
  "description": "A desktop coding agent that connects models, tools, local workspaces, and long-running software tasks.",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:renderer": "vite --config config/vite.renderer.config.ts",
    "dev:bridge": "tsc -p config/tsconfig.main.json && node dist/main/main/dev-bridge.js",
    "dev:main": "tsc -p config/tsconfig.main.json && electron dist/main/main/index.js",
    "build:main": "tsc -p config/tsconfig.main.json",
    "build:renderer": "vite build --config config/vite.renderer.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron dist/main/main/index.js",
    "pack": "./scripts/pack.sh",
    "pack:mac": "./scripts/pack.sh mac",
    "pack:win": "./scripts/pack.sh win",
    "pack:linux": "./scripts/pack.sh linux",
    "pack:all": "./scripts/pack.sh all",
    "pack:dir": "npm run build && electron-builder --dir --config.electronDist=./node_modules/electron/dist",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "codex:sync-reference": "node scripts/codex-reference-sync.mjs"
  },
  "keywords": [
    "agent",
    "coding-agent",
    "electron",
    "react",
    "llm",
    "openai-compatible",
    "developer-tools"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/nexa.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/nexa/issues"
  },
  "homepage": "https://github.com/your-org/nexa#readme",
  "license": "ISC",
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chokidar": "^3.6.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.nexa.app",
    "productName": "Nexa",
    "electronDist": "./node_modules/electron/dist",
    "icon": "resources/icon",
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
